# ============================================================
# Variables de Entorno — TiendaMiBarrio (Docker)
# ============================================================
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
# ============================================================

# ---- MySQL ----
# Contraseña del usuario root de MySQL
DB_PASSWORD=rootpassword

# Nombre de la base de datos
DB_NAME=tienda_mi_barrio

# Puerto externo para MySQL (el interno siempre es 3306)
DB_PORT_EXTERNAL=3307

# ---- Next.js App ----
# Puerto para la aplicación web
APP_PORT=3000

# Secreto para cifrar sesiones (mínimo 32 caracteres)
SESSION_SECRET=cambiar_esto_por_un_secreto_de_32_caracteres
